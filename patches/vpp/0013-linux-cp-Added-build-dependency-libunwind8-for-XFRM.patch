From 4958c7a4553d03532032c20932f5ab5905bff904 Mon Sep 17 00:00:00 2001
From: Viacheslav Hletenko <v.gletenko@vyos.io>
Date: Thu, 13 Feb 2025 11:37:36 +0000
Subject: [PATCH 13/21] linux-cp: Added build dependency libunwind8 for XFRM

Added `libunwind8` to build dependencies required by
`linux-cp` for XFRM
---
 Makefile | 1 +
 1 file changed, 1 insertion(+)

diff --git a/Makefile b/Makefile
index d8f1061d5..aa54f6089 100644
--- a/Makefile
+++ b/Makefile
@@ -109,6 +109,7 @@ DEB_DEPENDS += jq # for extracting test summary from .json report (hs-test)
 DEB_DEPENDS += libiberty-dev
 DEB_DEPENDS += nasm libnuma-dev # for make-ext-deps
 DEB_DEPENDS += libnl-xfrm-3-200 # for linux-cp XFRM extension
+DEB_DEPENDS += libunwind8 # for linux-cp XFRM extension
 
 LIBFFI=libffi6 # works on all but 20.04 and debian-testing
 ifeq ($(OS_VERSION_ID),24.04)
-- 
2.39.5

