From 37c2bd8d3b384e164be3e97b2fe305e717c26d13 Mon Sep 17 00:00:00 2001
From: Fullroot <51375681+AndriiFullroot@users.noreply.github.com>
Date: Thu, 5 Feb 2026 16:07:46 +0100
Subject: [PATCH] T8231: Removed PPPoE-input feature setup (#41)

Considering that there is a ethernet type registration for PPPoE traffic,
there is no need to set up the feature. With setupped feature, there is
an issue when non-PPPoE traffic ends up in PPPoE nodes.

Change-Id: Ib0ee9a11a58ab6bcfb5cff16dd914506f5b1ddc8

Signed-off-by: Andrii Melnychenko <a.melnychenko@vyos.io>
---
 src/plugins/pppoe/pppoe_cp.c | 3 ---
 1 file changed, 3 deletions(-)

diff --git a/src/plugins/pppoe/pppoe_cp.c b/src/plugins/pppoe/pppoe_cp.c
index c5b682243..1dde90211 100644
--- a/src/plugins/pppoe/pppoe_cp.c
+++ b/src/plugins/pppoe/pppoe_cp.c
@@ -44,9 +44,6 @@ pppoe_add_del_cp (u32 cp_if_index, u32 dp_if_index, u8 is_add)
 	}
     }
 
-  vnet_feature_enable_disable ("device-input", "pppoe-input", cp_if_index,
-			       is_add, 0, 0);
-
   if (is_add)
     {
       if (dp_if_index < vec_len (pem->cp_if_index_by_sw_if_index) &&
-- 
2.39.5

