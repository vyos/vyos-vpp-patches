new file mode 100644
index 000000000..ab34c523f
--- /dev/null
+++ b/src/plugins/linux-cp/lcp_nl.api
@@ -0,0 +1,38 @@
+/* Hey Emacs use -*- mode: C -*- */
+/*
+ * Linux Control Plane API
+ *
+ * Copyright 2020 Rubicon Communications, LLC.
+ *
