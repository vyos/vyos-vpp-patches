+/** \brief Add/delete DET44 identity mapping
+    @param client_index - opaque cookie to identify the sender
+    @param context - sender context, to match reply w/ request
+    @param is_add - true if add, false if delete
+    @param addr - IPv4 address
+    @param protocol - IP protocol (0 for address-only mapping)
+    @param port - port number (0 for address-only mapping)
+    @param flags - mapping flags (DET44_IDENTITY_FLAG_ADDR_ONLY)
+    @param tag - opaque string tag
+*/
+autoreply define det44_add_del_identity_mapping {
+  u32 client_index;
+  u32 context;
+  bool is_add;
+  vl_api_ip4_address_t addr;
+  u8 protocol;
+  u16 port;
+  vl_api_nat_config_flags_t flags;
+  string tag[64];
+};
+
+/** \brief Dump DET44 identity mappings
+    @param client_index - opaque cookie to identify the sender
+    @param context - sender context, to match reply w/ request
+*/
+define det44_identity_mapping_dump {
+  u32 client_index;
+  u32 context;
+};
+
+/** \brief DET44 identity mapping details response
+    @param context - sender context, to match reply w/ request
+    @param addr - IPv4 address
+    @param protocol - IP protocol
+    @param port - port number
+    @param flags - mapping flags
+    @param tag - opaque string tag
+*/
+define det44_identity_mapping_details {
+  u32 context;
+  vl_api_ip4_address_t addr;
+  u8 protocol;
+  u16 port;
+  vl_api_nat_config_flags_t flags;
+  string tag[64];
+};
