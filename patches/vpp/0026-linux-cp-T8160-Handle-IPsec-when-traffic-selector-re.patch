From b613d6989795607b68634c30c75e3b004409603d Mon Sep 17 00:00:00 2001
From: Denys Haryachyy <garyachy@gmail.com>
Date: Wed, 21 Jan 2026 12:53:44 +0200
Subject: [PATCH] linux-cp: T8160 - Handle IPsec when traffic selector resolves
 to local

This commit implements three related improvements for IPsec tunnel
management when traffic selectors resolve to local (local0):

1. Skip FIB route installation: When local or remote traffic selector
   prefix has FIB_ENTRY_FLAG_LOCAL, skip installing FIB routes to
   prevent routing conflicts with local delivery.

2. Cleanup tunnel and SAs: When a policy is added and the traffic
   selector resolves to local, not only skip FIB installation but also
   clean up the tunnel and all associated Security Associations (SAs).

3. Punt no-such-tunnel packets to Linux: Register IPsec no-such-tunnel
   punt reasons to linux-cp-punt node, forwarding encrypted IPsec
   packets with no matching tunnel to Linux via interface pairs.

4. Use reqid for SA matching in get_reverse_sa_by_tun_ip() to prevent
   wrong SA association when multiple tunnels share the same outer IPs.
---
 src/plugins/linux-cp/lcp_interface.c |   8 ++
 src/plugins/linux-cp/lcp_ipsec.c     | 161 +++++++++++++++++++++++----
 2 files changed, 150 insertions(+), 19 deletions(-)

diff --git a/src/plugins/linux-cp/lcp_interface.c b/src/plugins/linux-cp/lcp_interface.c
index d831d83f9..2528eb1ae 100644
--- a/src/plugins/linux-cp/lcp_interface.c
+++ b/src/plugins/linux-cp/lcp_interface.c
@@ -1294,6 +1294,14 @@ lcp_interface_init (vlib_main_t *vm)
   vlib_punt_register (punt_hdl, ipsec_punt_reason[IPSEC_PUNT_IP6_SPI_UDP_0],
 		      "linux-cp-punt");
 
+  /* punt IPsec packets with no tunnel to Linux */
+  vlib_punt_register (punt_hdl,
+		      ipsec_punt_reason[IPSEC_PUNT_IP4_NO_SUCH_TUNNEL],
+		      "linux-cp-punt");
+  vlib_punt_register (punt_hdl,
+		      ipsec_punt_reason[IPSEC_PUNT_IP6_NO_SUCH_TUNNEL],
+		      "linux-cp-punt");
+
   /* punt all unknown ports */
   udp_punt_unknown (vm, 0, 1);
   udp_punt_unknown (vm, 1, 1);
diff --git a/src/plugins/linux-cp/lcp_ipsec.c b/src/plugins/linux-cp/lcp_ipsec.c
index e975c769f..730dd648d 100644
--- a/src/plugins/linux-cp/lcp_ipsec.c
+++ b/src/plugins/linux-cp/lcp_ipsec.c
@@ -28,6 +28,42 @@
 /* size in bytes */
 #define GCM_SALT_SIZE 4
 
+/*
+ * Check if the FIB entry for an IP prefix has FIB_ENTRY_FLAG_LOCAL.
+ * That flag is used for local delivery, e.g. routes from Linux with no
+ * corresponding VPP interface (route-no-paths punted routes), receive
+ * routes for interface addresses, etc. Returns 1 if the prefix is local,
+ * 0 otherwise.
+ */
+static inline int
+lcp_xfrm_prefix_resolves_to_local (ip46_address_t *addr, u8 prefix_len,
+				   u8 is_ipv6)
+{
+  fib_prefix_t pfx;
+  fib_node_index_t fei;
+  u32 fib_index;
+  fib_entry_flag_t flags;
+
+  clib_memset (&pfx, 0, sizeof (pfx));
+  pfx.fp_proto = is_ipv6 ? FIB_PROTOCOL_IP6 : FIB_PROTOCOL_IP4;
+  pfx.fp_len = prefix_len;
+  if (is_ipv6)
+    pfx.fp_addr.ip6 = addr->ip6;
+  else
+    pfx.fp_addr.ip4 = addr->ip4;
+
+  fib_index = fib_table_find (pfx.fp_proto, 0);
+  if (fib_index == ~0)
+    return 0;
+
+  fei = fib_table_lookup (fib_index, &pfx);
+  if (fei == FIB_NODE_INDEX_INVALID)
+    return 0;
+
+  flags = fib_entry_get_flags (fei);
+  return (flags & FIB_ENTRY_FLAG_LOCAL) != 0;
+}
+
 /*
  * Wrapper around xfrmnl_sa_get_aead_params that normalizes key length
  * for GCM algorithms to handle libnl padding issues.
@@ -114,6 +150,7 @@ typedef struct sa_life_limits
   u64 soft_packet_limit;
   u64 hard_packet_limit;
   u32 sa_id;
+  u32 reqid;
 
   /* Used in tunnel mode */
   int tun_sw_if_idx;
@@ -713,7 +750,7 @@ get_sa_by_sa_id (u32 sa_id)
 
 ipsec_sa_t *
 get_reverse_sa_by_tun_ip (ip_address_t *saddr, ip_address_t *daddr, u8 is_ipv6,
-			  u8 dir)
+			  u8 dir, u32 reqid)
 {
   sa_life_limits_t *life = NULL;
   ipsec_sa_t *sa;
@@ -737,22 +774,19 @@ get_reverse_sa_by_tun_ip (ip_address_t *saddr, ip_address_t *daddr, u8 is_ipv6,
       if (!is_ipv6 &&
 	  !ip4_address_compare (&daddr->ip.ip4, &sa->tunnel.t_src.ip.ip4) &&
 	  !ip4_address_compare (&saddr->ip.ip4, &sa->tunnel.t_dst.ip.ip4) &&
-	  !life->sa_in_tunnel)
+	  !life->sa_in_tunnel && life->reqid == reqid)
 	found = 1;
-      else if (!ip6_address_compare (&daddr->ip.ip6,
+      else if (is_ipv6 &&
+	       !ip6_address_compare (&daddr->ip.ip6,
 				     &sa->tunnel.t_src.ip.ip6) &&
 	       !ip6_address_compare (&saddr->ip.ip6,
 				     &sa->tunnel.t_dst.ip.ip6) &&
-	       !life->sa_in_tunnel)
+	       !life->sa_in_tunnel && life->reqid == reqid)
 	found = 1;
 
       if (found)
 	{
-	  if (dir)
-	    life->sa_in_tunnel = !dir;
-	  else
-	    /* Its enabled only for inb sa */
-	    life->sa_in_tunnel = 1;
+	  life->sa_in_tunnel = 1;
 	  return sa;
 	}
     }
@@ -862,7 +896,7 @@ lcp_xfrm_create_ipip_tunnel (struct xfrmnl_sa *sa, int *sw_if_index,
 
 static inline void
 lcp_xfrm_protect_tunnel (int sw_if_index, u8 is_ipv6, u32 sa_id, u8 dir,
-			 ip_address_t *saddr, ip_address_t *daddr)
+			 ip_address_t *saddr, ip_address_t *daddr, u32 reqid)
 {
   u32 sa_out = 0, sa_in = 0, *sa_ins = NULL;
   ipsec_sa_t *sa;
@@ -870,10 +904,11 @@ lcp_xfrm_protect_tunnel (int sw_if_index, u8 is_ipv6, u32 sa_id, u8 dir,
   if (dir == 0)
     {
       sa_in = sa_id;
-      sa = get_reverse_sa_by_tun_ip (saddr, daddr, is_ipv6, dir);
-      /* Outb sa is not yet configured */
+      sa = get_reverse_sa_by_tun_ip (saddr, daddr, is_ipv6, dir, reqid);
       if (!sa)
 	{
+	  NL_XFRM_DBG ("Reverse SA not yet configured (dir=%u, reqid=%u)", dir,
+		       reqid);
 	  return;
 	}
       sa_out = sa->id;
@@ -881,10 +916,11 @@ lcp_xfrm_protect_tunnel (int sw_if_index, u8 is_ipv6, u32 sa_id, u8 dir,
   else
     {
       sa_out = sa_id;
-      sa = get_reverse_sa_by_tun_ip (saddr, daddr, is_ipv6, dir);
-      /* Inb sa is not yet configured */
+      sa = get_reverse_sa_by_tun_ip (saddr, daddr, is_ipv6, dir, reqid);
       if (!sa)
 	{
+	  NL_XFRM_DBG ("Reverse SA not yet configured (dir=%u, reqid=%u)", dir,
+		       reqid);
 	  return;
 	}
       sa_in = sa->id;
@@ -938,7 +974,8 @@ lcp_xfrm_configure_route_mode (struct xfrmnl_sa *sa, u8 is_ipv6,
     return;
   ((sa_life_limits_t *) p[0])->tun_sw_if_idx = sw_if_index;
 
-  lcp_xfrm_protect_tunnel (sw_if_index, is_ipv6, sa_id, dir, saddr, daddr);
+  lcp_xfrm_protect_tunnel (sw_if_index, is_ipv6, sa_id, dir, saddr, daddr,
+			   xfrmnl_sa_get_reqid (sa));
 }
 
 static inline void
@@ -1014,6 +1051,7 @@ nl_xfrm_sa_add (struct xfrmnl_sa *sa)
   lifetime.hard_packet_limit =
     xfrmnl_ltime_cfg_get_hard_packetlimit (lifetimes);
   lifetime.sa_id = id;
+  lifetime.reqid = xfrmnl_sa_get_reqid (sa);
   lifetime.sa_in_tunnel = 0;
   lifetime.tun_sw_if_idx = ~0;
 
@@ -1341,6 +1379,78 @@ fib_entry_cfg (ip_address_t *sel_daddr, u8 sel_daddr_prefix, u32 if_idx,
   vec_free (rpath);
 }
 
+/*
+ * Release an SA by its sa_id: unlock the VPP SA and free the
+ * corresponding lifetime_by_sa_id entry.
+ */
+static inline void
+lcp_xfrm_sa_id_release (u32 sa_id)
+{
+  uword *p;
+  int rv;
+
+  rv = ipsec_sa_unlock_id (sa_id);
+  if (rv)
+    NL_XFRM_ERR ("SA %x deletion failure (err: %d)", sa_id, rv);
+
+  p = hash_get (lifetime_by_sa_id, sa_id);
+  if (p)
+    {
+      sa_life_limits_t *life = (sa_life_limits_t *) p[0];
+      hash_unset (lifetime_by_sa_id, sa_id);
+      vec_free (life);
+    }
+}
+
+static walk_rc_t
+lcp_xfrm_release_tun_sa_cb (index_t itpi, void *arg)
+{
+  ipsec_tun_protect_t *itp = ipsec_tun_protect_get (itpi);
+  ipsec_sa_t *sa;
+
+  sa = ipsec_sa_get (itp->itp_out_sa);
+  lcp_xfrm_sa_id_release (sa->id);
+
+  FOR_EACH_IPSEC_PROTECT_INPUT_SA (itp, sa,
+				   { lcp_xfrm_sa_id_release (sa->id); })
+
+  return WALK_CONTINUE;
+}
+
+static inline void
+lcp_xfrm_tun_cfg_destroy_by_sa_id (u32 sa_id)
+{
+  uword *p = NULL;
+  sa_life_limits_t *life = NULL;
+  int sw_if_index = ~0;
+  int rv;
+
+  p = hash_get (lifetime_by_sa_id, sa_id);
+  if (!p)
+    return;
+  life = (sa_life_limits_t *) p[0];
+  sw_if_index = life->tun_sw_if_idx;
+
+  if (sw_if_index == ~0)
+    return;
+
+  ipsec_tun_protect_walk_itf (sw_if_index, lcp_xfrm_release_tun_sa_cb, NULL);
+
+  rv = ipsec_tun_protect_del (sw_if_index, NULL);
+  if (rv)
+    {
+      NL_XFRM_ERR ("Tunnel protect del failure (err: %d)", rv);
+      return;
+    }
+
+  if (nm->interface_type == NL_INTERFACE_TYPE_IPIP)
+    rv = ipip_del_tunnel (sw_if_index);
+  else
+    rv = ipsec_itf_delete (sw_if_index);
+  if (rv)
+    NL_XFRM_ERR ("Tunnel deletion failure (err: %d)", rv);
+}
+
 static inline void
 lcp_xfrm_tun_cfg_destroy (ip_address_t *sel_daddr, u8 sel_daddr_prefix,
 			  u8 is_ipv6)
@@ -1499,10 +1609,23 @@ nl_xfrm_sp_add (struct xfrmnl_sp *sp, u8 num)
 
   if (IS_ROUTE_MODE_ENABLED)
     {
-      /*
-       * Add a fib entry for dest tun selectors via ipipX interface.
-       */
-      lcp_xfrm_tun_update_fib (sa_id, &sel_daddr, sel_daddr_prefix, is_ipv6);
+      if (!lcp_xfrm_prefix_resolves_to_local (&sel_saddr.ip, sel_saddr_prefix,
+					      is_ipv6) &&
+	  !lcp_xfrm_prefix_resolves_to_local (&sel_daddr.ip, sel_daddr_prefix,
+					      is_ipv6))
+	{
+	  /*
+	   * Add a fib entry for dest tun selectors via ipipX interface.
+	   */
+	  lcp_xfrm_tun_update_fib (sa_id, &sel_daddr, sel_daddr_prefix,
+				   is_ipv6);
+	}
+      else
+	{
+	  NL_XFRM_DBG ("TS resolves to local, destroying tunnel cfg for SA %x",
+		       sa_id);
+	  lcp_xfrm_tun_cfg_destroy_by_sa_id (sa_id);
+	}
       return;
     }
 
